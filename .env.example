APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
# Production: LOG_STACK=daily,slack — routes errors to Slack webhook as well as file.
# Local:      LOG_STACK=daily       — file only, avoids Slack noise.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Use "warning" in production. Only set "debug" locally — debug emits every
# query, event, and framework internal and will flood logs in production.
LOG_LEVEL=warning
LOG_DAILY_DAYS=30
LOG_AUDIT_DAYS=90
# Slack alerting (set in production only)
# LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# LOG_SLACK_USERNAME="${APP_NAME}"
# LOG_SLACK_LEVEL=error

# ── Database ─────────────────────────────────────────────────────────────────
# Local: sqlite. Production: pgsql (required for metric_snapshots partitioning).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=dc_mcp
# DB_USERNAME=dc_mcp_user
# DB_PASSWORD=
# DB_SSLMODE=require

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: must be true to restrict cookies to HTTPS only.
# Override to false only for local HTTP dev.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── Broadcasting / Filesystem / Queue ────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Queue
# -----
# DB_QUEUE_RETRY_AFTER must exceed the longest job timeout (180s for briefing jobs).
# Default is 210s. Increase if you add longer-running jobs.
DB_QUEUE_RETRY_AFTER=210

# ── Cache ────────────────────────────────────────────────────────────────────
# Local: database. Production: redis (avoids DB round-trips on every cache hit).
CACHE_STORE=database
# CACHE_PREFIX=

# Dashboard viz query cache TTL in seconds (default 300 = 5 minutes)
VIZ_CACHE_TTL=300

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# Leave blank (not "null") for no password. "null" is treated as a literal string.
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Replace with a real address on your domain — "hello@example.com" will fail SPF/DKIM.
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── AI (Anthropic / Claude) ──────────────────────────────────────────────────
# Required for daily briefing generation. BriefingGenerator will throw on startup
# if ANTHROPIC_MODEL is missing — there is no silent fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google (Gmail + Calendar MCP adapters) ───────────────────────────────────
# Required for Google Calendar and Gmail integrations.
# Adapters throw RuntimeException if these are missing — no dummy fallback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://yourdomain.com/oauth/google/callback

# ── Zoho (Cliq MCP adapter) ──────────────────────────────────────────────────
# Required for Zoho Cliq notifications and OAuth token refresh.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# ── Meta / Facebook (Ads MCP adapter) ────────────────────────────────────────
# Required to validate incoming Meta webhook challenges.
# Adapter returns a 400 error if missing — previously used 'dummy-verify-token'
# which would accept any forged webhook from an attacker knowing the fallback.
META_WEBHOOK_VERIFY_TOKEN=

# ── WhatsApp (notification channel) ─────────────────────────────────────────
# WHATSAPP_WEBHOOK_URL=https://api.whatsapp.example/send

# ── Health check ─────────────────────────────────────────────────────────────
# Set to a comma-separated list of trusted IPs that can access /health/detailed
HEALTH_ALLOWED_IPS=127.0.0.1,::1

# ── Horizon ──────────────────────────────────────────────────────────────────
# Horizon requires Redis. In production, also set:
#   QUEUE_CONNECTION=redis
#   HORIZON_CONNECTION=redis
#   CACHE_STORE=redis
# HORIZON_NAME="${APP_NAME}"
# HORIZON_PATH=horizon
# HORIZON_CONNECTION=redis

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
# Enable source maps locally only — never in production:
# VITE_SOURCEMAP=true

# ── Production override checklist ────────────────────────────────────────────
# When deploying, ensure the following are set correctly:
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://yourdomain.com
#   DB_CONNECTION=pgsql
#   DB_SSLMODE=require
#   SESSION_ENCRYPT=true
#   SESSION_SECURE_COOKIE=true
#   LOG_STACK=daily,slack
#   LOG_LEVEL=warning
#   QUEUE_CONNECTION=redis
#   CACHE_STORE=redis
#   MAIL_MAILER=smtp  (or ses/postmark)
#   MAIL_FROM_ADDRESS=noreply@yourdomain.com
